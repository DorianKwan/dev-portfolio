#!/usr/bin/env sh
echo "🔍 Running pre-push checks..."

# Run linting
echo "📝 Linting code..."
pnpm run lint
if [ $? -ne 0 ]; then
  echo "❌ Linting failed. Please fix the issues before pushing."
  exit 1
fi

# Run tests
echo "🧪 Running tests..."
pnpm run test
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix the failing tests before pushing."
  exit 1
fi

# Run type checking
if [ -f "tsconfig.json" ]; then
  echo "🔍 Type checking..."
  pnpm exec tsc --noEmit
  if [ $? -ne 0 ]; then
    echo "❌ Type checking failed. Please fix the type errors before pushing."
    exit 1
  fi
fi

# Run build check
echo "🏗️ Testing build..."
pnpm run build
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Please fix the build errors before pushing."
  exit 1
fi

echo "✅ All checks passed!"